# ============================================================
# Taskify — Environment Variables
# Copy to .env for local dev.  Set these in Railway for prod.
# ============================================================

# --- Supabase ---
SUPABASE_URL=https://dcewsdzdbiwjaiaophnm.supabase.co
SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_SERVICE_KEY=<your-service-role-key>

# --- Auth ---
# Where Supabase redirects after Google OAuth consent
AUTH_REDIRECT_URL=http://localhost:3000/auth/callback

# --- Encryption (for storing Canvas / Google tokens) ---
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=<your-fernet-key>

# --- Reflex / Railway ---
API_URL=http://localhost:8000
PORT=8000

# --- Canvas LMS (added later) ---
# CANVAS_BASE_URL=https://your-school.instructure.com
# CANVAS_CLIENT_ID=
# CANVAS_CLIENT_SECRET=

# --- Google Calendar (added later) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# --- Claude / Anthropic (for syllabus parsing) ---
# ANTHROPIC_API_KEY=
