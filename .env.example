# ============================================================
# Taskify — Environment Variables (Vercel)
# ============================================================
# Copy to .env.local for local dev. Paste into Vercel → Project
# → Settings → Environment Variables for production.
# ============================================================

# --- Supabase (PUBLIC — safe to ship to the browser) ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# Server-side mirror — used by Python serverless functions in /api/
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_SERVICE_KEY=<your-service-role-key>

# --- Encryption (Canvas / Google tokens at rest) ---
# Generate once: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=<your-fernet-key>

# --- Gemini (free tier) ---
# Get a key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=<your-gemini-api-key>
GEMINI_MODEL=gemini-2.5-flash-lite

# --- Vercel Cron auth ---
# Set this to a long random string. Vercel sends it as `Authorization: Bearer <CRON_SECRET>`
# on every cron call. Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
CRON_SECRET=<random-string>

# --- Local dev only ---
# Tells Next.js to forward /api/* to a Python server on this URL.
# Leave unset in production (Vercel serves Python serverless directly).
# PYTHON_API_URL=http://localhost:8000
